# Copy this file to ".env" and fill in your values.  cp .env.example .env

# ---- Anthropic (required) ----
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx
# Vision-capable model. sonnet = cheaper for big batches; opus = strongest for finals.
ANTHROPIC_MODEL=claude-sonnet-4-6

# ---- Input mode ----
#   local-folder  folder of images named with the metadata (recommended; default)
#   local         a CSV + a folder of images
#   drive         Google Form responses Sheet + Drive uploads
#   drive-folder  read images straight from a Drive folder (coming soon)
INPUT_MODE=local-folder

# ---- local-folder mode (filenames carry the metadata — see NAMING.md) ----
# School__Category__Student__YYYY-MM-DD__HHMM[__RegID].jpg
IMAGES_DIR=input/images

# ---- local mode (CSV) ----
INPUT_CSV=input/submissions.csv

# ---- drive mode (reads the Google Form responses Sheet + Drive uploads) ----
# Path to a Google service-account JSON key with read access to the Sheet & Drive folder.
GOOGLE_SERVICE_ACCOUNT_JSON=service-account.json
SHEET_ID=
SHEET_TAB=Form Responses 1

# ---- drive-folder mode (coming soon) ----
DRIVE_FOLDER_ID=

# ---- output ----
OUTPUT_DIR=output
