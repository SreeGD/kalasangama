# Copy this file to ".env" and fill in your values.  cp .env.example .env

# ---- Anthropic (required) ----
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx
# Vision-capable model. sonnet = cheaper for big batches; opus = strongest for finals.
ANTHROPIC_MODEL=claude-sonnet-4-6

# ---- Input mode: "local" (default) or "drive" ----
INPUT_MODE=local

# ---- local mode ----
INPUT_CSV=input/submissions.csv
IMAGES_DIR=input/images

# ---- drive mode (reads the Google Form responses Sheet + Drive uploads) ----
# Path to a Google service-account JSON key with read access to the Sheet & Drive folder.
GOOGLE_SERVICE_ACCOUNT_JSON=service-account.json
SHEET_ID=
SHEET_TAB=Form Responses 1

# ---- output ----
OUTPUT_DIR=output
